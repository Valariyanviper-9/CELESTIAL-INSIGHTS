{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and consultation status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "description": "User's email address" },
        "hasUsedFreeConsultation": { "type": "boolean", "description": "Whether the user has already used their free consultation" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "name", "email", "hasUsedFreeConsultation", "createdAt"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Stores appointment booking details.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who booked" },
        "userName": { "type": "string", "description": "Name of the user" },
        "date": { "type": "string", "description": "Date of appointment" },
        "time": { "type": "string", "description": "Time of appointment" },
        "consultationType": { "type": "string", "enum": ["Vastu Shastra", "Numerology", "Detailed Astrology"] },
        "priceCharged": { "type": "number", "description": "Price paid for the session" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time", "description": "Booking timestamp" }
      },
      "required": ["userId", "userName", "date", "time", "consultationType", "priceCharged", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Booking records"
    }
  }
}
